  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:uml001:aegis:GossipPolicy",
  "title": "GossipPolicy",
  "type": "object",
  "required": [
    "ttl_min",
    "ttl_max",
    "max_hops",
    "dedup_window_sec"
  ],
  "properties": {
    "ttl_min": {
      "type": "integer",
      "minimum": 0
    },
    "ttl_max": {
      "type": "integer",
      "minimum": 1
    },
    "max_hops": {
      "type": "integer",
      "minimum": 1
    },
    "dedup_window_sec": {
      "type": "integer",
      "minimum": 1
    }
  },
  "additionalProperties": false
}
