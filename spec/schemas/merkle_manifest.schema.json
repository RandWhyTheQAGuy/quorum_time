{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:uml001:vault:MerkleManifest",
  "title": "VaultMerkleManifest",
  "type": "object",
  "required": [
    "file_name",
    "file_start_time",
    "file_end_time",
    "merkle_root",
    "entry_count"
  ],
  "properties": {
    "file_name": { "type": "string" },
    "file_start_time": { "type": "integer", "minimum": 0 },
    "file_end_time": { "type": "integer", "minimum": 0 },
    "merkle_root": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$"
    },
    "entry_count": { "type": "integer", "minimum": 0 }
  },
  "additionalProperties": false
}