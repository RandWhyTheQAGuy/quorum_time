{
  "$comment": "Quorum Time — Open Trusted Time & Distributed Verification Framework. Copyright 2026 Randy Spickler (github.com/RandWhyTheQAGuy). SPDX-License-Identifier: Apache-2.0",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:uml001:aegis:SignedStateEnvelope",
  "title": "SignedStateEnvelope",
  "description": "JSON interchange form of proto/signed_state.proto SignedState. payload/signature are strict standard base64-encoded protobuf bytes.",
  "type": "object",
  "required": [
    "logical_time_ns",
    "event_id"
  ],
  "additionalProperties": false,
  "properties": {
    "$comment": {
      "type": "string",
      "description": "Optional SPDX / project notice for file-level metadata (not part of runtime SignedState)."
    },
    "logical_time_ns": {
      "type": "integer",
      "minimum": 0
    },
    "event_id": {
      "type": "string",
      "minLength": 1
    },
    "payload": {
      "type": "string",
      "contentEncoding": "base64",
      "pattern": "^$|^(?:[A-Za-z0-9+/]{4})*(?:[A-Za-z0-9+/]{2}==|[A-Za-z0-9+/]{3}=)?$",
      "description": "Opaque event bytes (binary in protobuf), base64-encoded."
    },
    "signature": {
      "type": "string",
      "contentEncoding": "base64",
      "pattern": "^$|^(?:[A-Za-z0-9+/]{4})*(?:[A-Za-z0-9+/]{2}==|[A-Za-z0-9+/]{3}=)?$"
    },
    "key_id": {
      "type": "string"
    },
    "gossip": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "hops": {
          "type": "integer",
          "minimum": 0
        },
        "ttl": {
          "type": "integer",
          "minimum": 0
        },
        "validated": {
          "type": "boolean"
        },
        "origin_node_id": {
          "type": "string"
        }
      }
    },
    "anchor_proof": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "version": {
          "type": "integer",
          "minimum": 0
        },
        "is_merkle_root": {
          "type": "boolean"
        },
        "observation_hash": {
          "type": "string"
        },
        "quorum_size": {
          "type": "integer",
          "minimum": 0
        },
        "authority_set": {
          "type": "string"
        },
        "event_id": {
          "type": "string"
        },
        "event_hash": {
          "type": "string"
        }
      }
    }
  }
}
