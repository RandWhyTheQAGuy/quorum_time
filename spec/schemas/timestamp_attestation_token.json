{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "TimestampAttestationToken",
  "type": "object",
  "required": [
    "unix_time",
    "median_rtt",
    "drift_ppm",
    "quorum_servers",
    "quorum_hash",
    "signature"
  ],
  "properties": {

    "unix_time": {
      "type": "integer",
      "description": "Quorum validated UNIX timestamp"
    },

    "median_rtt": {
      "type": "integer",
      "description": "Median RTT across quorum"
    },

    "drift_ppm": {
      "type": "integer",
      "description": "Estimated clock drift in ppm"
    },

    "quorum_servers": {
      "type": "array",
      "items": { "type": "string" }
    },

    "quorum_hash": {
      "type": "string",
      "description": "SHA256 hash of server quorum"
    },

    "signature": {
      "type": "string",
      "description": "HMAC signature over the token payload"
    }

  }
}