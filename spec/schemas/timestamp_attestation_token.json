{
  "$comment": "Quorum Time — Open Trusted Time & Distributed Verification Framework. Copyright 2026 Randy Spickler (github.com/RandWhyTheQAGuy). SPDX-License-Identifier: Apache-2.0",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:uml001:bft:TimestampAttestationToken",
  "title": "TimestampAttestationToken",
  "type": "object",
  "required": [
    "unix_time",
    "median_rtt_ms",
    "drift_ppm",
    "servers",
    "quorum_hash_hex",
    "signature_hex"
  ],
  "properties": {
    "unix_time": {
      "type": "integer",
      "minimum": 0,
      "description": "Quorum validated UNIX timestamp."
    },
    "median_rtt_ms": {
      "type": "integer",
      "minimum": 0,
      "description": "Median RTT across quorum in milliseconds."
    },
    "drift_ppm": {
      "type": "integer",
      "minimum": 0,
      "description": "Estimated clock drift in ppm."
    },
    "servers": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "quorum_hash_hex": {
      "type": "string",
      "pattern": "^[0-9a-fA-F]{64}$",
      "description": "SHA-256 hash of server quorum."
    },
    "signature_hex": {
      "type": "string",
      "pattern": "^[0-9a-fA-F]+$",
      "description": "HMAC/Ed25519 signature over token payload."
    }
  },
  "additionalProperties": false
}
