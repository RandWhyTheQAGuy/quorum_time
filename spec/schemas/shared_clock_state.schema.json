{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://uml001.org/schema/shared_clock_state.json",
  "title": "SharedClockState",
  "type": "object",
  "required": [
    "agreed_time",
    "applied_drift",
    "last_updated_unix",
    "key_version"
  ],
  "properties": {
    "agreed_time": {
      "type": "integer",
      "minimum": 0,
      "description": "Consensus Unix time (seconds)."
    },
    "applied_drift": {
      "type": "integer",
      "description": "Drift adjustment applied during sync."
    },
    "last_updated_unix": {
      "type": "integer",
      "minimum": 0,
      "description": "Strong time when state was committed."
    },
    "key_version": {
      "type": "integer",
      "minimum": 1,
      "description": "Version of cryptographic key in effect."
    }
  },
  "additionalProperties": false
}