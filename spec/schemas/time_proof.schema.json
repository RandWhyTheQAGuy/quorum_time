{
  "$comment": "Quorum Time — Open Trusted Time & Distributed Verification Framework. Copyright 2026 Randy Spickler (github.com/RandWhyTheQAGuy). SPDX-License-Identifier: Apache-2.0",
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "QuorumTimeProof",
  "type": "object",
  "required": [
    "agreed_time",
    "observation_hash",
    "quorum_size",
    "proof_signature"
  ],
  "properties": {
    "agreed_time": {
      "type": "integer",
      "description": "Unix timestamp agreed by quorum"
    },
    "observation_hash": {
      "type": "string",
      "description": "Hash of observation set"
    },
    "quorum_size": {
      "type": "integer",
      "description": "Number of validated servers"
    },
    "proof_signature": {
      "type": "string",
      "description": "HMAC signature of the proof"
    }
  }
}
