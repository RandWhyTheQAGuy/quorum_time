{
  "$comment": "Quorum Time — Open Trusted Time & Distributed Verification Framework. Copyright 2026 Randy Spickler (github.com/RandWhyTheQAGuy). SPDX-License-Identifier: Apache-2.0",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:uml001:vault:Config",
  "title": "ColdVaultConfig",
  "type": "object",
  "required": [
    "base_directory",
    "max_file_size_bytes",
    "max_file_age_seconds"
  ],
  "properties": {
    "base_directory": {
      "type": "string",
      "minLength": 1
    },
    "max_file_size_bytes": {
      "type": "integer",
      "minimum": 1024
    },
    "max_file_age_seconds": {
      "type": "integer",
      "minimum": 60
    }
  },
  "additionalProperties": false
}
